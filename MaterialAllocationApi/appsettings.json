{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=material_allocation;Username=dotnetter;Password=password",
    "PostgresMigrator": "Host=localhost;Port=5432;Database=material_allocation;Username=material_allocation_migrator;Password=password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReservationExpiry": {
    "IntervalSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                        "Warning",
        "Microsoft.Hosting.Lifetime":       "Information",
        "Microsoft.EntityFrameworkCore":    "Warning",
        "System":                           "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "AllowedHosts": "*"
}